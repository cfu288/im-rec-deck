#!/usr/bin/env bash
# Format staged markdown via mdformat, then re-stage the (possibly-reformatted)
# files so the commit reflects the canonical form.
#
# Excludes:
#   docs/                   — generated by scripts/build_docs.py; mdformat
#                             escapes the Liquid `{{ ... }}` link targets and
#                             breaks Jekyll rendering.
#   spec/knowledge-catalog/ — hand-curated, intentionally not reformatted.
#
# Install (per clone): git config core.hooksPath .githooks

set -euo pipefail

files=$(
    git diff --cached --name-only --diff-filter=ACM \
        | grep -E '\.md$' \
        | grep -vE '^(docs/|spec/knowledge-catalog/)' \
        || true
)

[ -z "$files" ] && exit 0

echo "$files" | xargs uvx --from mdformat --with mdformat-gfm --with mdformat-frontmatter mdformat
echo "$files" | xargs git add
