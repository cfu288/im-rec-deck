# Secrets — never commit
.env

# build/ artifacts are tracked so the .apkg is downloadable straight from
# GitHub (linked from docs/) and so cards.jsonl is available for reproducible
# re-packaging without re-running paid card generation. Same copyright posture
# as the public deck download. Runtime-only state stays ignored.
build/.enrich-state.json

# Node deps for the puppeteer helpers
scripts/node_modules

# Python bytecode
__pycache__/
*.pyc

# macOS
.DS_Store

# Copyrighted source documents — ignore everything under sources/ except the README.
# The manifest.yaml + download/import scripts reproduce the tree locally.
sources/*
!sources/README.md

# references/ is tracked — it's the most expensive artifact in the chain
# (paid enrichment of paraphrased recommendations + numerics across every
# manifest version) and the canonical body that cards.jsonl + docs summaries
# project from. Same copyright posture as build/. Losing it costs API spend
# to rebuild, so we keep it under version control as the durable knowledge
# layer. Runtime-only state stays ignored.
references/.enrich-state.json
